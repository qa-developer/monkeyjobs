---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import SiteJsonLd from '~/components/common/SiteJsonLd.astro';
import WelcomeLoader from '~/components/widgets/WelcomeLoader.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <SiteJsonLd pageTitle={metadata?.title} pageDescription={metadata?.description} />
    <Analytics />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />

    <script is:inline>
      // Preserve Vite-injected <style> tags during View Transitions.
      // In dev, Tailwind v4 + @tailwindcss/vite inject CSS as inline <style>
      // elements. ClientRouter swap replaces <head> contents and drops them,
      // leaving the page unstyled until next full reload.
      (function () {
        if (window.__mjPreserveStylesInstalled) return;
        window.__mjPreserveStylesInstalled = true;

        function snapshotStyles() {
          const nodes = document.head.querySelectorAll(
            'style, link[rel="stylesheet"], link[as="style"]'
          );
          window.__mjStyleSnapshot = Array.from(nodes).map((n) => n.cloneNode(true));
        }

        function restoreStyles() {
          if (!window.__mjStyleSnapshot) return;
          const head = document.head;
          window.__mjStyleSnapshot.forEach((node) => {
            const tag = node.tagName.toLowerCase();
            let selector;
            if (tag === 'link' && node.getAttribute('href')) {
              selector = `link[href="${CSS.escape(node.getAttribute('href'))}"]`;
            } else if (tag === 'style' && node.getAttribute('data-vite-dev-id')) {
              selector = `style[data-vite-dev-id="${CSS.escape(node.getAttribute('data-vite-dev-id'))}"]`;
            }
            if (selector && head.querySelector(selector)) return;
            head.appendChild(node.cloneNode(true));
          });
        }

        snapshotStyles();
        document.addEventListener('astro:before-swap', snapshotStyles);
        document.addEventListener('astro:after-swap', restoreStyles);
        document.addEventListener('astro:page-load', restoreStyles);
      })();
    </script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <WelcomeLoader />
    <slot />

    <BasicScripts />
  </body>
</html>
