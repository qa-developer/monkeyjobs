---
import Layout from '~/layouts/PageLayout.astro';
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';
import { services } from '~/data/services';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const siteUrl = SITE?.site || '';
const pageUrl = `${siteUrl}/services/${service.slug}`;

const metadata = {
  title: service.metaTitle,
  description: service.metaDescription,
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}/#service`,
  name: service.name,
  serviceType: service.name,
  description: service.metaDescription,
  url: pageUrl,
  provider: { '@id': `${siteUrl}/#organization` },
  areaServed: [
    { '@type': 'Country', name: 'Colombia' },
    { '@type': 'Country', name: 'México' },
    { '@type': 'Country', name: 'Estados Unidos' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: service.name,
    itemListElement: service.capabilities.map((c) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: c.title, description: c.description },
    })),
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${siteUrl}/services` },
    { '@type': 'ListItem', position: 3, name: service.navLabel, item: pageUrl },
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline={service.tagline}
    subtitle={service.heroSubtitle}
    actions={[{ variant: 'primary', text: 'Cotizar este servicio', href: '/contact', icon: 'tabler:rocket' }]}
    image={service.image}
  >
    <Fragment slot="title" set:html={service.heroTitleHtml} />

    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="xl" opacity={0.45} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.25} flip rotate={180} />
      </div>
    </Fragment>
  </Hero>

  <Features
    id="features"
    title={`Qué incluye ${service.name}`}
    subtitle={service.intro}
    columns={2}
    items={service.capabilities}
  />

  <FAQs
    title="Preguntas frecuentes"
    subtitle={`Dudas comunes sobre ${service.name.toLowerCase()}.`}
    tagline="FAQs"
    classes={{ container: 'max-w-4xl' }}
    items={service.faqs.map((f) => ({ title: f.q, description: f.a }))}
  />

  <CallToAction
    actions={[{ variant: 'primary', text: 'Cotiza tu proyecto', href: '/contact', icon: 'tabler:rocket' }]}
    title={`¿Listo para empezar con ${service.navLabel.toLowerCase()}?`}
    subtitle="Cuéntanos qué necesitas. Conversamos sin compromiso y te damos claridad técnica y de negocio."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="lg" opacity={0.32} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.32} flip rotate={180} />
      </div>
    </Fragment>
  </CallToAction>

  <StructuredData data={serviceJsonLd} />
  <StructuredData data={faqJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />
</Layout>
