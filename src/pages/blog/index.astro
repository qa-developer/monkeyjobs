---
import Layout from '~/layouts/PageLayout.astro';
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Image from '~/components/common/Image.astro';
import { SITE } from 'astrowind:config';
import { articles } from '~/data/articles';

const siteUrl = SITE?.site || '';

const metadata = {
  title: 'Blog — Insights de desarrollo de software',
  description:
    'Artículos y guías de MonkeyJobs sobre desarrollo de software a la medida, apps móviles, inteligencia artificial y tecnología para empresas.',
};

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteUrl}/blog/#blog`,
  name: 'Blog de MonkeyJobs',
  description: metadata.description,
  url: `${siteUrl}/blog`,
  inLanguage: 'es-CO',
  publisher: { '@id': `${siteUrl}/#organization` },
  blogPost: articles.map((a) => ({
    '@type': 'BlogPosting',
    headline: a.title,
    description: a.description,
    url: `${siteUrl}/blog/${a.slug}`,
    datePublished: a.datePublished,
    image: a.image.src,
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
  ],
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Blog">
    <Fragment slot="title">
      Insights de <span class="text-accent dark:text-white">desarrollo de software</span>
    </Fragment>
    <Fragment slot="bg">
      <SpiralDecoration position="top-right" size="xl" opacity={0.4} />
      <SpiralDecoration position="bottom-left" size="lg" opacity={0.22} flip rotate={180} />
    </Fragment>
  </HeroText>

  <section class="px-4 sm:px-6 mx-auto max-w-5xl pb-12 md:pb-16">
    <div class="grid gap-8 sm:grid-cols-2">
      {
        articles.map((a) => (
          <a
            href={`/blog/${a.slug}`}
            class="group flex flex-col rounded-md overflow-hidden shadow-lg dark:border dark:border-slate-700 hover:shadow-xl transition"
          >
            <Image
              src={a.image.src}
              alt={a.image.alt}
              width={600}
              height={338}
              widths={[400, 600]}
              sizes="(max-width: 640px) 100vw, 400px"
              format="webp"
              class="w-full aspect-video object-cover"
            />
            <div class="flex flex-col flex-auto p-5">
              <div class="flex flex-wrap gap-2 mb-2">
                {a.tags.slice(0, 2).map((t) => (
                  <span class="text-xs font-medium uppercase tracking-wide text-secondary dark:text-blue-200">{t}</span>
                ))}
              </div>
              <h2 class="text-xl font-bold leading-snug group-hover:text-link transition">{a.title}</h2>
              <p class="mt-2 text-muted flex-auto">{a.excerpt}</p>
              <span class="mt-4 text-sm font-medium text-link">Leer artículo →</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <StructuredData data={blogJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />
</Layout>
