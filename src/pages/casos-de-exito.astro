---
import Layout from '~/layouts/PageLayout.astro';
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Stats from '~/components/widgets/Stats.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { cases } from '~/data/cases';

const siteUrl = SITE?.site || '';

const metadata = {
  title: 'Casos de éxito — Proyectos de software que hemos construido',
  description:
    'Casos de éxito de MonkeyJobs por sector: fintech, e-commerce, salud y logística. Retos reales resueltos con desarrollo a la medida, integraciones e inteligencia artificial.',
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Casos de éxito de MonkeyJobs',
  itemListElement: cases.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.title,
    description: c.summary,
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Casos de éxito', item: `${siteUrl}/casos-de-exito` },
  ],
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Casos de éxito"
    title="Proyectos que hemos construido"
    subtitle="Una muestra del trabajo que hacemos, organizada por sector. Retos reales de negocio resueltos con ingeniería sólida, integraciones y, cuando aporta, inteligencia artificial."
  >
    <Fragment slot="bg">
      <SpiralDecoration position="top-right" size="xl" opacity={0.4} />
      <SpiralDecoration position="bottom-left" size="lg" opacity={0.22} flip rotate={180} />
    </Fragment>
  </HeroText>

  <section class="px-4 sm:px-6 mx-auto max-w-6xl pb-8 md:pb-12">
    <div class="grid gap-8 md:gap-10">
      {
        cases.map((c, i) => (
          <article
            id={c.slug}
            class="grid md:grid-cols-2 gap-6 md:gap-8 items-center rounded-md overflow-hidden shadow-lg dark:border dark:border-slate-700 scroll-mt-[90px]"
          >
            <div class={`relative min-h-[220px] md:min-h-[320px] ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <Image
                src={c.image.src}
                alt={c.image.alt}
                width={760}
                height={500}
                widths={[400, 760]}
                sizes="(max-width: 768px) 100vw, 380px"
                format="webp"
                class="absolute inset-0 w-full h-full object-cover"
              />
            </div>
            <div class="p-6 md:p-8">
              <div class="flex items-center gap-2 mb-3 text-secondary dark:text-blue-200">
                <Icon name={c.icon} class="w-5 h-5" />
                <span class="text-xs font-bold uppercase tracking-wide">{c.sector}</span>
              </div>
              <h2 class="text-2xl font-bold tracking-tight mb-3">{c.title}</h2>
              <p class="text-muted mb-4">{c.summary}</p>

              <div class="space-y-3 text-sm">
                <p><strong class="font-semibold">Reto:</strong> <span class="text-muted">{c.challenge}</span></p>
                <p><strong class="font-semibold">Solución:</strong> <span class="text-muted">{c.solution}</span></p>
              </div>

              <div class="flex flex-wrap gap-2 mt-4">
                {c.stack.map((t) => (
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-blue-50 text-blue-700 dark:bg-slate-800 dark:text-blue-200">
                    {t}
                  </span>
                ))}
              </div>

              <ul class="mt-5 space-y-2">
                {c.outcomes.map((o) => (
                  <li class="flex items-start gap-2 text-sm">
                    <Icon name="tabler:circle-check" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
                    <span>{o}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <Stats
    stats={[
      { title: 'Proyectos entregados', amount: '50+' },
      { title: 'Sectores atendidos', amount: '9+' },
      { title: 'Clientes que repiten', amount: '80%' },
      { title: 'Países', amount: '5' },
    ]}
  />

  <Testimonials
    title="Lo que dicen nuestros clientes"
    tagline="Testimonios"
    testimonials={[
      {
        testimonial: `El equipo de MonkeyJobs no solo cumplió con los tiempos, sino que nos propuso mejoras de producto que no habíamos considerado. Comunicación clara y entregables sólidos.`,
        name: 'Emily Kennedy',
        job: 'Product Manager',
        image: {
          src: 'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=930&q=80',
          alt: 'Emily Kennedy',
        },
      },
      {
        testimonial: `Mi catálogo en línea quedó hermoso y rapidísimo. El proceso fue fluido, sin tecnicismos innecesarios, y siempre supe en qué iba mi proyecto.`,
        name: 'Sarah Hansen',
        job: 'Fundadora de e-commerce',
        image: {
          src: 'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80',
          alt: 'Sarah Hansen',
        },
      },
      {
        testimonial: `Trabajamos con MonkeyJobs en un proyecto de IA aplicada y los resultados superaron lo que esperábamos. Equipo técnico real, no comerciales pintados de developer.`,
        name: 'Mark Wilkinson',
        job: 'CTO en pyme tecnológica',
        image: {
          src: 'https://images.unsplash.com/photo-1545167622-3a6ac756afa4?ixlib=rb-4.0.3&auto=format&fit=crop&w=824&q=80',
          alt: 'Mark Wilkinson',
        },
      },
    ]}
  />

  <CallToAction
    actions={[{ variant: 'primary', text: 'Cuéntanos tu proyecto', href: '/contact', icon: 'tabler:rocket' }]}
    title="¿Quieres ser el próximo caso de éxito?"
    subtitle="Cuéntanos tu reto. Te damos claridad técnica y de negocio, y un plan para construirlo bien."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="lg" opacity={0.32} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.32} flip rotate={180} />
      </div>
    </Fragment>
  </CallToAction>

  <StructuredData data={itemListJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />
</Layout>
