---
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Nosotros — Equipo MonkeyJobs en Bogotá',
  description:
    'Conoce a MonkeyJobs S.A.S.: casa de desarrollo de software en Bogotá con +8 años, equipo de 20+ ingenieros senior y +50 proyectos entregados en LATAM y EE.UU.',
};

const siteUrl = SITE?.site || '';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Nosotros', item: `${siteUrl}/about` },
  ],
};

const aboutJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${siteUrl}/about`,
  about: { '@id': `${siteUrl}/#organization` },
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Sobre nosotros"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Equipo MonkeyJobs',
    }}
  >
    <Fragment slot="title">
      Somos MonkeyJobs S.A.S. <br />
      <span class="text-accent dark:text-white"> Una casa de desarrollo de software con ADN técnico</span>
    </Fragment>

    <Fragment slot="subtitle">
      Nacimos en Bogotá con una convicción simple: el buen software se construye con criterio, ética y obsesión por
      el detalle. Acompañamos a startups, pymes y áreas digitales a llevar sus ideas a producción con un equipo que
      entiende negocio y código a partes iguales.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="xl" opacity={0.45} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.25} flip rotate={180} />
      </div>
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="MonkeyJobs en números"
    stats={[
      { title: 'Sede', amount: '1' },
      { title: 'Equipo', amount: '20+' },
      { title: 'Proyectos entregados', amount: '50+' },
      { title: 'Años de experiencia', amount: '8+' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-left" size="md" opacity={0.18} />
        <SpiralDecoration position="bottom-right" size="md" opacity={0.18} flip />
      </div>
    </Fragment>
  </Stats>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Industrias en las que trabajamos"
    subtitle="Aplicamos buenas prácticas y stack moderno en sectores donde el software realmente mueve la aguja."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Educación',
        description:
          'Plataformas LMS, contenido interactivo y herramientas para instituciones educativas y EdTech.',
        icon: 'tabler:school',
      },
      {
        title: 'Fintech',
        description:
          'Procesos de pago, billeteras digitales, scoring y dashboards financieros con altos requisitos de seguridad.',
        icon: 'tabler:coin',
      },
      {
        title: 'Salud',
        description:
          'Plataformas para clínicas, citas médicas, telemedicina e integración con sistemas de historia clínica.',
        icon: 'tabler:vaccine',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'E-commerce y retail',
        description:
          'Tiendas online, marketplaces, integración con POS, inventarios y plataformas de logística.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Logística y operaciones',
        description:
          'Sistemas de tracking, optimización de rutas, integraciones con couriers y dashboards operativos.',
        icon: 'tabler:truck',
      },
      {
        title: 'Inmobiliario',
        description:
          'Portales de propiedades, CRMs especializados, tours virtuales y herramientas para constructoras.',
        icon: 'tabler:building',
      },
      {
        title: 'Servicios profesionales',
        description:
          'Plataformas para agencias, consultorías, despachos legales y firmas que necesitan digitalizarse.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Gobierno y ONGs',
        description:
          'Soluciones digitales para entidades públicas y organizaciones del tercer sector con foco en accesibilidad.',
        icon: 'tabler:flag',
      },
      {
        title: 'SaaS y startups',
        description:
          'Acompañamos a fundadores desde el MVP hasta el product-market fit con foco en escalabilidad.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Industrias atendidas por MonkeyJobs',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Nuestros valores"
    subtitle="Las cosas que nos definen y que están presentes en cada proyecto, cada reunión y cada commit."
    items={[
      {
        title: 'Cliente en el centro',
        description:
          'Tu objetivo de negocio guía las decisiones técnicas. Hacemos preguntas duras al inicio para no asumir nada.',
      },
      {
        title: 'Mejora continua',
        description:
          'Nos formamos constantemente. Stack actualizado, code katas internas y revisiones de aprendizaje en cada cierre de proyecto.',
      },
      {
        title: 'Ética y transparencia',
        description:
          'Sin sobrecostos sorpresa, sin tiempos inflados, sin "venta de humo". Decimos lo que cuesta y lo que toma.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Logros que respaldan el trabajo"
    subtitle="Reconocimientos, alianzas y resultados que confirman que el camino es el correcto."
    isReversed={true}
    callToAction={{
      text: 'Ver casos de éxito',
      href: '/',
    }}
    items={[
      {
        title: 'Clientes en LATAM y EE.UU.',
        description:
          'Atendemos proyectos en Colombia, México, Chile, Estados Unidos y España con equipos remoto-first.',
        icon: 'tabler:globe',
      },
      {
        title: 'Feedback positivo y recurrente',
        description:
          'Más del 80% de nuestros clientes vuelve por una segunda fase o nos refiere a otra empresa.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Reconocidos por excelencia técnica',
        description:
          'Charlas en comunidades Angular, IA y product, además de mentorías a equipos junior dentro y fuera de MonkeyJobs.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Dónde estamos"
    tagline="Ubicación"
    columns={4}
    items={[
      {
        title: 'Colombia',
        description: 'Sede principal · LATAM',
      },
      {
        title: 'Remote-first',
        description: 'Equipo distribuido en LATAM',
      },
      {
        title: 'Disponibilidad GMT-5',
        description: 'Horario alineado con clientes en América',
      },
      {
        title: 'Soporte 24/7',
        description: 'Para sistemas críticos en producción',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Hablemos"
    tagline="Contáctanos"
    columns={2}
    items={[
      {
        title: 'Escríbenos por chat',
        description:
          'Respondemos en minutos durante horario laboral. Cuéntanos qué necesitas y te conectamos con el perfil correcto.',
        icon: 'tabler:messages',
      },
      {
        title: 'Agenda una llamada',
        description:
          'Sesión inicial de 30 minutos sin compromiso para entender tu proyecto y ver si encajamos como equipo.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <StructuredData data={breadcrumbJsonLd} />
  <StructuredData data={aboutJsonLd} />
</Layout>
