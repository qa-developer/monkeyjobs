---
import Layout from '~/layouts/PageLayout.astro';

import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'MonkeyJobs — Casa de desarrollo de software en Bogotá',
  ignoreTitleTemplate: true,
  description:
    'Casa de desarrollo de software en Bogotá. Construimos web, apps móviles, sistemas empresariales e inteligencia artificial a la medida. Equipo senior, time-to-market real.',
};

const faqs = [
  {
    title: '¿Cuánto tiempo toma desarrollar un proyecto?',
    description:
      'Depende del alcance. Un MVP funcional toma entre 6 y 12 semanas. Plataformas más complejas pueden tomar de 3 a 9 meses. En la fase de descubrimiento definimos cronograma realista y entregables por sprint.',
  },
  {
    title: '¿Trabajan con startups o solo con empresas grandes?',
    description:
      'Ambos. Tenemos planes y procesos pensados para startups en etapa temprana, pymes en crecimiento y áreas digitales de empresas consolidadas. Te acompañamos según el momento de tu negocio.',
  },
  {
    title: '¿Cómo es el proceso de cotización?',
    description:
      'Conversación inicial gratuita para entender tu necesidad. Luego enviamos una propuesta con alcance, cronograma e inversión. Sin compromiso hasta que firmes la orden de trabajo.',
  },
  {
    title: '¿Quién es dueño del código?',
    description:
      'Tú. Todo el código, diseños, documentación y propiedad intelectual generada queda 100% a tu nombre. Recibes acceso completo a repositorios desde el día uno.',
  },
  {
    title: '¿Ofrecen soporte y mantenimiento después del lanzamiento?',
    description:
      'Sí. Tenemos planes de mantenimiento evolutivo, soporte 24/7 para sistemas críticos y bolsas de horas mensuales para mejoras continuas. Tú eliges el nivel.',
  },
  {
    title: '¿Pueden integrarse con mi equipo interno?',
    description:
      'Por supuesto. Trabajamos como extensión de tu equipo, asistimos a tus ceremonias ágiles, usamos tu stack de comunicación y nos adaptamos a tu proceso. Sin egos.',
  },
];

const siteUrl = SITE?.site || '';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.title,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.description,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: siteUrl,
    },
  ],
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Cotiza tu proyecto',
        href: '/contact',
        icon: 'tabler:rocket',
      },
      { text: 'Ver servicios', href: '#features' },
    ]}
    image={{
      src: '~/assets/images/hero_img2.png',
      alt: 'MonkeyJobs — Casa de desarrollo de software premium',
      width: 1480,
      height: 878,
      class: 'mx-auto w-full max-w-3xl lg:max-w-4xl h-auto',
    }}
  >
    <Fragment slot="title">
      Construimos <span class="hidden xl:inline">productos digitales</span>
      <span class="text-accent dark:text-white"> a la medida</span> con IA + ingeniería sólida
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">MonkeyJobs S.A.S.</span> es una casa de desarrollo de software con sede en Bogotá. Diseñamos
        y construimos web, apps móviles, sistemas empresariales e inteligencia artificial para acelerar tu operación.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">MonkeyJobs: Software a la medida.</span>
      Ideal para startups, pymes, áreas digitales, retail, fintech y proyectos que necesitan resultados reales.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="xl" opacity={0.45} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.25} flip rotate={180} />
      </div>
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Filosofía:" description="Simplicidad, buenas prácticas y alto rendimiento desde el primer commit." />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Servicios"
    title="Lo que MonkeyJobs construye contigo"
    subtitle="Trabajamos como una extensión de tu equipo. Del descubrimiento al deploy, te acompañamos en cada fase con criterio técnico y enfoque en negocio."
    items={[
      {
        title: 'Desarrollo web a la medida',
        description:
          'Sitios y aplicaciones web modernas con Angular, React, Astro y SSR. Performance, SEO y escalabilidad como estándar.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Apps móviles nativas y cross-platform',
        description:
          'iOS, Android y Flutter. Producto pulido, store-ready, integrado con tus sistemas y servicios cloud.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Inteligencia Artificial y agentes',
        description:
          'Integramos modelos generativos, agentes autónomos y pipelines de ML en tus flujos críticos de negocio.',
        icon: 'tabler:robot',
      },
      {
        title: 'Sistemas empresariales e integraciones',
        description:
          'ERPs, CRMs, APIs y middleware. Conectamos lo que tu operación necesita, sin parches frágiles.',
        icon: 'tabler:server-bolt',
      },
      {
        title: 'Consultoría y arquitectura',
        description:
          'Auditoría técnica, definición de roadmap y acompañamiento estratégico para escalar tu producto.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Equipos dedicados (staff augmentation)',
        description:
          'Perfiles seniors integrados a tu equipo en sprints reales. Sin intermediarios, sin sorpresas.',
        icon: 'tabler:users-group',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Cómo trabajamos"
    title="Construido sobre fundamentos modernos"
    items={[
      {
        title: 'Stack actualizado y probado en producción',
        description:
          'Angular 17+, Astro, Node, TypeScript, Tailwind, .NET, Python. Elegimos la herramienta correcta para cada proyecto.',
      },
      {
        title: 'Arquitectura escalable desde el día uno',
        description:
          'Diseñamos para crecer: SSR, micro-frontends, CI/CD, observabilidad, modular monoliths o microservicios según el caso.',
      },
      {
        title: 'Calidad como contrato',
        description:
          'Code review, testing automatizado, linters y revisiones de seguridad integradas al flujo. Sin atajos.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Equipo MonkeyJobs trabajando',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Ingeniería con criterio y resultados medibles</h3>
      Ventaja competitiva real al adoptar prácticas líderes de la industria.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Diseño centrado en el usuario',
        description: `UI/UX pensada para tu cliente final. Prototipado, validación y diseño visual alineado a tu marca.`,
      },
      {
        title: 'Múltiples opciones de layout',
        description:
          'Exploramos arquitecturas y diseños hasta encontrar la mejor estructura para tu contenido y conversión.',
      },
      {
        title: 'Diseño responsive completo',
        description:
          'Rendimiento óptimo en cualquier dispositivo. Experiencia consistente desde móvil hasta pantalla 4K.',
      },
      {
        title: 'Integración multimedia',
        description:
          'Imágenes optimizadas, video, modelos 3D, animaciones y elementos interactivos que enganchan al visitante.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Planos de arquitectura de software',
    }}
  >
    <Fragment slot="content">Tu presencia digital, contada como debería contarse.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Engagement medible',
        description:
          'Métricas, eventos y analítica desde el día uno. No optimizamos lo que no podemos medir.',
      },
      {
        title: 'Mejora continua',
        description:
          'Mantenimiento evolutivo y actualizaciones constantes para que tu producto no envejezca antes de tiempo.',
      },
      {
        title: 'Time-to-market eficiente',
        description:
          'No reinventamos la rueda. Componentes, plantillas y procesos propios para lanzar antes con MonkeyJobs.',
      },
      {
        title: 'Soporte cercano',
        description: `Comunicación directa con el equipo técnico. Sin intermediarios, sin tickets infinitos.`,
      },
    ]}
    image={{
      src: '~/assets/images/crecimiento_digital.png',
      alt: 'MonkeyJobs — Diseñado para acompañar tu crecimiento digital',
      width: 565,
      height: 460,
    }}
  >
    <Fragment slot="content">Diseñado para acompañar tu crecimiento.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Así trabajamos contigo, paso a paso."
    items={[
      {
        title: 'Paso 1: <span class="font-medium">Descubrimiento</span>',
        description:
          'Entendemos tu negocio, tus usuarios y tus restricciones. Definimos alcance, objetivos y métricas de éxito en sesiones de trabajo conjunto.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Paso 2: <span class="font-medium">Diseño y arquitectura</span>',
        description:
          'Prototipos UX/UI, arquitectura técnica, stack y roadmap. Validamos contigo antes de escribir una sola línea de código.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Paso 3: <span class="font-medium">Construcción ágil</span>',
        description:
          'Sprints quincenales con entregables reales. Visibilidad total del avance, feedback continuo y cero sorpresas al final.',
        icon: 'tabler:code',
      },
      {
        title: '¡Listo para producción!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Proceso de desarrollo de software de MonkeyJobs: descubrimiento, diseño, construcción ágil y go-live',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Capacidades que entregamos"
    subtitle="Componentes y prácticas que aplicamos en cada producto que sale al aire."
    tagline="Capacidades"
    items={[
      {
        title: 'Diseño UI/UX',
        description: 'Identidad visual, prototipos interactivos y design systems escalables para tu producto.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Frontend moderno',
        description:
          'Angular, React, Astro, Vue. Componentes accesibles, performance optimizada y SEO técnico.',
        icon: 'flat-color-icons:gallery',
      },
      {
        title: 'Backend robusto',
        description:
          'Node, .NET, Python, Go. APIs REST y GraphQL, microservicios y arquitecturas event-driven.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Bases de datos',
        description:
          'PostgreSQL, MongoDB, MySQL, Redis. Modelado, optimización de consultas y migraciones seguras.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Cloud y DevOps',
        description:
          'AWS, Azure, GCP, Vercel. CI/CD, infra como código, monitoreo y costos optimizados.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Inteligencia Artificial',
        description: 'LLMs, agentes autónomos, RAG, embeddings y automatización de procesos con IA.',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: 'Mobile',
        description: 'iOS nativo, Android nativo y Flutter. Store deployment, push notifications y analytics integrados.',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: 'Integraciones',
        description:
          'Pasarelas de pago, ERPs, CRMs, WhatsApp Business, APIs gubernamentales y servicios de terceros.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Seguridad',
        description: 'Auditoría, hardening, OWASP top 10, autenticación multifactor y cumplimiento normativo.',
        icon: 'flat-color-icons:database',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Preguntas frecuentes"
    subtitle="Resolvemos las dudas más comunes antes de empezar un proyecto contigo."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={faqs}
  />

  <StructuredData data={faqJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Proyectos entregados', amount: '50+' },
      { title: 'Reducción de costos', amount: '-70%' },
      { title: 'Time-to-market', amount: '2-6 sem' },
      { title: 'Equipo MonkeyJobs', amount: '20+' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-left" size="md" opacity={0.18} />
        <SpiralDecoration position="bottom-right" size="md" opacity={0.18} flip />
      </div>
    </Fragment>
  </Stats>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Cotiza tu proyecto',
        href: '/contact',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="title">
      ¿Listo para construir&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">algo grande?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Cuéntanos qué necesitas. Conversamos sin compromiso y te damos claridad técnica y de negocio. <br class="hidden md:inline"
      />En MonkeyJobs no vendemos humo: vendemos resultados.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="lg" opacity={0.32} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.32} flip rotate={180} />
      </div>
    </Fragment>
  </CallToAction>
</Layout>
