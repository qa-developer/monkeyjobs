---
import Layout from '~/layouts/Layout.astro';
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `Error 404`;
const metadata = {
  title,
  description: 'La página que buscas no existe. Vuelve al inicio de MonkeyJobs.',
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="relative flex items-center h-full p-16 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <SpiralDecoration position="top-right" size="xl" opacity={0.35} />
      <SpiralDecoration position="bottom-left" size="lg" opacity={0.25} flip rotate={180} />
    </div>
    <div class="container relative flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">Esta página no existe.</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          Pero no te preocupes: hay mucho por descubrir en la home de MonkeyJobs.
        </p>
        <a rel="noopener noreferrer" href={getHomePermalink()} class="btn ml-4">Volver al inicio</a>
      </div>
    </div>
  </section>
</Layout>
