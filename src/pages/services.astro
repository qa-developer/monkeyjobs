---
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Servicios de desarrollo de software a la medida',
  description:
    'Desarrollo web, apps móviles (iOS, Android, Flutter), IA y agentes, sistemas empresariales, e-commerce, DevOps y staff augmentation. Equipo senior MonkeyJobs.',
};

const siteUrl = SITE?.site || '';

const servicesCatalog = [
  { name: 'Desarrollo web', description: 'Sitios y aplicaciones web con Angular, React, Astro y Next. Performance, SEO técnico y SSR.' },
  { name: 'Apps móviles', description: 'iOS y Android nativo, Flutter, React Native. Publicación en stores, push notifications, analytics.' },
  { name: 'Inteligencia Artificial', description: 'Integración de LLMs, agentes autónomos, RAG y automatización de procesos.' },
  { name: 'Sistemas empresariales', description: 'ERPs a la medida, CRMs, integraciones con sistemas legacy y middleware confiable.' },
  { name: 'E-commerce', description: 'Tiendas online performantes, integraciones con pasarelas de pago, logística y marketing.' },
  { name: 'Backend y APIs', description: 'APIs REST, GraphQL, microservicios, event-driven. Node, .NET, Python y Go.' },
  { name: 'DevOps y Cloud', description: 'AWS, Azure, GCP. CI/CD, infra como código, monitoreo, observabilidad y optimización de costos.' },
  { name: 'Consultoría técnica', description: 'Auditoría de código, roadmap, arquitectura y acompañamiento estratégico.' },
  { name: 'Staff augmentation', description: 'Perfiles seniors integrados a tu equipo en sprints reales, sin intermediarios.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Desarrollo de software a la medida',
  provider: { '@id': `${siteUrl}/#organization` },
  areaServed: [
    { '@type': 'Country', name: 'Colombia' },
    { '@type': 'Country', name: 'México' },
    { '@type': 'Country', name: 'Estados Unidos' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios MonkeyJobs',
    itemListElement: servicesCatalog.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.name,
        description: s.description,
      },
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${siteUrl}/services` },
  ],
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Servicios"
    subtitle="Diseñamos, construimos y mantenemos productos digitales con criterio técnico y enfoque de negocio. Desde plataformas web hasta agentes inteligentes, te acompañamos en cada etapa."
    actions={[{ variant: 'primary', text: 'Cotizar proyecto', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Servicios de desarrollo de software a la medida de MonkeyJobs: web, apps móviles e IA',
    }}
  >
    <Fragment slot="title">
      Software <span class="text-accent dark:text-white">a la medida</span> para tu negocio
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="xl" opacity={0.45} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.25} flip rotate={180} />
      </div>
    </Fragment>
  </Hero>

  <!-- Features2 Widget ************** -->

  <Features2
    title="Nuestras líneas de servicio"
    subtitle="Soluciones end-to-end para cada momento de tu producto."
    columns={3}
    items={[
      {
        title: 'Desarrollo web',
        description:
          'Sitios y aplicaciones web con Angular, React, Astro y Next. Performance, SEO técnico y SSR. Diseño responsive y accesible.',
        icon: 'tabler:world-code',
      },
      {
        title: 'Apps móviles',
        description:
          'iOS y Android nativo, Flutter, React Native. Publicación en stores, push notifications, analytics y deep linking.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Inteligencia Artificial',
        description: `Integración de LLMs, agentes autónomos, RAG y automatización de procesos. Casos reales en producción.`,
        icon: 'tabler:robot',
      },
      {
        title: 'Sistemas empresariales',
        description:
          'ERPs a la medida, CRMs, integraciones con sistemas legacy y middleware confiable para tus operaciones.',
        icon: 'tabler:server-bolt',
      },
      {
        title: 'E-commerce',
        description:
          'Tiendas online performantes, integraciones con pasarelas de pago, logística y plataformas de marketing.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Backend y APIs',
        description:
          'APIs REST, GraphQL, microservicios, event-driven. Node, .NET, Python y Go en arquitecturas escalables.',
        icon: 'tabler:api',
      },
      {
        title: 'DevOps y Cloud',
        description:
          'AWS, Azure, GCP. CI/CD, infra como código, monitoreo, observabilidad y optimización de costos.',
        icon: 'tabler:cloud-cog',
      },
      {
        title: 'Consultoría técnica',
        description: `Auditoría de código, roadmap, arquitectura y acompañamiento estratégico para tu equipo o startup.`,
        icon: 'tabler:bulb',
      },
      {
        title: 'Staff augmentation',
        description:
          'Perfiles seniors integrados a tu equipo en sprints reales. Sin intermediarios, sin sorpresas en facturación.',
        icon: 'tabler:users-group',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Calidad como contrato',
        description:
          'Code review, testing automatizado, linters y revisiones de seguridad en cada PR. Sin atajos, sin "después lo arreglamos".',
        icon: 'tabler:wand',
      },
      {
        title: 'Personalización total',
        description:
          'Adaptamos cada solución a tu marca, procesos y objetivos. No vendemos plantillas: construimos productos únicos.',
        icon: 'tabler:settings',
      },
      {
        title: 'Componentes reutilizables',
        description:
          'Design systems, librerías internas y boilerplates propios que aceleran sin sacrificar calidad.',
        icon: 'tabler:presentation',
      },
      {
        title: 'Demos y prototipos navegables',
        description:
          'Validamos contigo antes de construir. Prototipos interactivos para alinear visión y reducir riesgo.',
        icon: 'tabler:carousel-horizontal',
      },
    ]}
    image={{
      src: '~/assets/images/caracteristicas_claves.png',
      alt: 'MonkeyJobs — Características clave del servicio',
      width: 1577,
      height: 1269,
      widths: [600, 900, 1200, 1577],
      sizes: '(max-width: 768px) 100vw, 600px',
      class: 'mx-auto w-full',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Características clave</h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Time-to-market real',
        description:
          'Procesos optimizados y stack moderno para acortar el tiempo entre la idea y la versión en producción.',
        icon: 'tabler:clock',
      },
      {
        title: 'Profesionalismo visible',
        description:
          'Documentación, repositorios bien estructurados y comunicación clara. Cada entregable se siente como senior.',
        icon: 'tabler:school',
      },
      {
        title: 'Costos predecibles',
        description:
          'Modelos de inversión claros: proyecto cerrado, bolsas de horas, equipo dedicado. Tú eliges el que mejor se ajuste.',
        icon: 'tabler:coin',
      },
      {
        title: 'Entregas en sprints',
        description:
          'Avances visibles cada 2 semanas, no al final del proyecto. Feedback temprano = producto mejor.',
        icon: 'tabler:file-download',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Beneficios de trabajar con MonkeyJobs',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Beneficios</h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Lo que dicen nuestros clientes"
    testimonials={[
      {
        testimonial: `El equipo de MonkeyJobs no solo cumplió con los tiempos, sino que nos propuso mejoras de producto que no habíamos considerado. Comunicación clara y entregables sólidos.`,
        name: 'Emily Kennedy',
        job: 'Product Manager',
        image: {
          src: 'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=930&q=80',
          alt: 'Emily Kennedy',
        },
      },
      {
        testimonial: `Mi catálogo en línea quedó hermoso y rapidísimo. El proceso fue fluido, sin tecnicismos innecesarios, y siempre supe en qué iba mi proyecto.`,
        name: 'Sarah Hansen',
        job: 'Fundadora de e-commerce',
        image: {
          src: 'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Sarah Hansen',
        },
      },
      {
        testimonial: `Trabajamos con MonkeyJobs en un proyecto de IA aplicada y los resultados superaron lo que esperábamos. Equipo técnico real, no comerciales pintados de developer.`,
        name: 'Mark Wilkinson',
        job: 'CTO en pyme tecnológica',
        image: {
          src: 'https://images.unsplash.com/photo-1545167622-3a6ac756afa4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=824&q=80',
          alt: 'Mark Wilkinson',
        },
      },
    ]}
    callToAction={{
      text: 'Habla con nosotros',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Cotiza tu proyecto',
        href: '/contact',
      },
    ]}
    title="¿Tienes un proyecto en mente?"
    subtitle="Cuéntanos qué necesitas. Conversamos sin compromiso y te entregamos claridad técnica y de negocio."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="lg" opacity={0.32} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.32} flip rotate={180} />
      </div>
    </Fragment>
  </CallToAction>

  <StructuredData data={serviceJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />
</Layout>
