---
import Layout from '~/layouts/PageLayout.astro';
import SpiralDecoration from '~/components/common/SpiralDecoration.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Planes y precios de desarrollo de software',
  description:
    'Modelos flexibles: sprint, equipo dedicado o proyecto cerrado. Cotización en USD o COP, sin costos ocultos. Empieza con un Sprint o escala con un equipo MonkeyJobs.',
};

const siteUrl = SITE?.site || '';

const pricingFaqs = [
  {
    title: '¿Los planes incluyen soporte después de la entrega?',
    description:
      'Sí. El plan "Equipo dedicado" incluye mantenimiento como parte del servicio. Para "Proyecto cerrado" ofrecemos 90 días de garantía y luego planes opcionales de soporte mensual.',
  },
  {
    title: '¿Tienen periodo de prueba?',
    description:
      'No vendemos producto enlatado, así que no hay trial. Lo que sí ofrecemos es una sesión inicial sin compromiso para validar si encajamos.',
  },
  {
    title: '¿Puedo cambiar de plan más adelante?',
    description:
      'Sí. Empezar con un Sprint y luego pasar a Equipo dedicado es uno de los caminos más comunes con nuestros clientes.',
  },
  {
    title: '¿Qué métodos de pago aceptan?',
    description:
      'Transferencia internacional, ACH, tarjeta de crédito y métodos locales en Colombia. Cotizaciones en USD o COP según prefieras.',
  },
  {
    title: '¿Hay costos ocultos?',
    description:
      'No. La cotización incluye todo lo definido en alcance. Si surge trabajo adicional, lo cotizamos por separado y lo firmas antes de empezar.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pricingFaqs.map((f) => ({
    '@type': 'Question',
    name: f.title,
    acceptedAnswer: { '@type': 'Answer', text: f.description },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Planes', item: `${siteUrl}/pricing` },
  ],
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Planes"
    title="Inversión clara para cada etapa de tu producto"
    subtitle="Modelos pensados para acompañarte desde el MVP hasta plataformas en producción. Sin sorpresas en la factura."
  >
    <Fragment slot="bg">
      <SpiralDecoration position="top-right" size="xl" opacity={0.4} />
      <SpiralDecoration position="bottom-left" size="lg" opacity={0.22} flip rotate={180} />
    </Fragment>
  </HeroText>

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Nuestros planes"
    subtitle="Paga solo por lo que tu proyecto necesita."
    prices={[
      {
        title: 'Sprint',
        subtitle: 'Ideal para validar ideas o resolver entregables puntuales',
        period: 'Cotización personalizada por sprint (2 semanas)',
        items: [
          {
            description: '1 perfil senior dedicado tiempo completo',
          },
          {
            description: 'Daily stand-up y demo al final del sprint',
          },
          {
            description: 'Repositorio, documentación y handoff completo',
          },
          {
            description: 'Soporte por chat durante el sprint',
          },
        ],
        callToAction: {
          text: 'Llámanos ya',
          href: '/contact',
        },
      },
      {
        title: 'Equipo dedicado',
        subtitle: 'Recomendado para productos en crecimiento',
        period: 'Inversión mensual según equipo',
        items: [
          {
            description: 'Equipo de 3 perfiles seniors (FE + BE + QA)',
          },
          {
            description: 'Product owner técnico asignado',
          },
          {
            description: 'Ceremonias ágiles integradas a tu equipo',
          },
          {
            description: 'CI/CD, observabilidad y documentación viva',
          },
          {
            description: 'Soporte de mantenimiento incluido',
          },
        ],
        callToAction: {
          text: 'Llámanos ya',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: 'popular',
      },
      {
        title: 'Proyecto cerrado',
        subtitle: 'Alcance definido, entrega llave en mano',
        period: 'Inversión según alcance del proyecto',
        items: [
          {
            description: 'Descubrimiento + diseño + construcción',
          },
          {
            description: 'Cronograma e hitos definidos en propuesta',
          },
          {
            description: 'Equipo asignado por fases del proyecto',
          },
          {
            description: 'Garantía de 90 días post lanzamiento',
          },
        ],
        callToAction: {
          text: 'Llámanos ya',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Qué incluye trabajar con MonkeyJobs"
    subtitle="Cosas que siempre van incluidas en cualquier plan, sin asteriscos ni letra chica."
    columns={2}
    items={[
      {
        title: 'Modelos flexibles',
        description: 'Elige entre sprints cortos, equipo dedicado o proyecto cerrado según tu momento.',
        icon: 'tabler:stairs',
      },
      {
        title: 'Precios transparentes',
        description: 'Inversión clara desde el primer contacto. Lo que ves es lo que pagas.',
        icon: 'tabler:flip-vertical',
      },
      {
        title: 'Pagos seguros',
        description: 'Cotizaciones en USD o COP. Facturación electrónica y métodos de pago internacionales.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Arranque rápido',
        description: 'Onboarding ágil. Empezamos a aportar valor desde la primera semana, no en el tercer mes.',
        icon: 'tabler:accessible',
      },
      {
        title: 'Escala cuando lo necesites',
        description: 'Sube o baja el tamaño del equipo según las fases del proyecto y tu presupuesto.',
        icon: 'tabler:chevrons-up',
      },
      {
        title: 'Soporte directo',
        description: 'Comunicación con el equipo técnico. Sin filtros, sin "te respondo cuando pueda".',
        icon: 'tabler:headset',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Cómo arrancamos contigo"
    tagline="proceso simple"
    isReversed={true}
    items={[
      {
        title: 'Conversación inicial',
        icon: 'tabler:number-1',
      },
      {
        title: 'Definición de alcance',
        icon: 'tabler:number-2',
      },
      {
        title: 'Propuesta y cotización',
        icon: 'tabler:number-3',
      },
      {
        title: 'Firma de orden de trabajo',
        icon: 'tabler:number-4',
      },
      {
        title: 'Kickoff y arranque de sprint',
        icon: 'tabler:number-5',
      },
      {
        title: 'Demos quincenales y feedback',
        icon: 'tabler:number-6',
      },
      {
        title: 'Entrega y go-live en producción',
        icon: 'tabler:number-7',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1536816579748-4ecb3f03d72a?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Proceso paso a paso MonkeyJobs',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Preguntas frecuentes sobre precios"
    subtitle="Aclaramos las dudas más comunes sobre cómo facturamos, qué incluyen los planes y cómo se ajustan al ritmo de tu proyecto."
    columns={1}
    items={pricingFaqs}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="¿Listo para arrancar tu proyecto?"
    subtitle="Únete a las empresas que ya están construyendo con MonkeyJobs."
    actions={[
      {
        variant: 'primary',
        text: 'Cotizar ahora',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <SpiralDecoration position="top-right" size="lg" opacity={0.32} />
        <SpiralDecoration position="bottom-left" size="lg" opacity={0.32} flip rotate={180} />
      </div>
    </Fragment>
  </CallToAction>

  <StructuredData data={faqJsonLd} />
  <StructuredData data={breadcrumbJsonLd} />
</Layout>
