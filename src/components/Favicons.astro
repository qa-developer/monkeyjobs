---
import favIcon from '~/assets/favicons/favicon.ico';
import favIconSvg from '~/assets/favicons/favicon.svg';
import appleTouchIcon from '~/assets/favicons/apple-touch-icon.png';
import favicon96 from '~/assets/favicons/favicon-96x96.png';
import favicon32 from '~/assets/favicons/favicon-32x32.png';
import favicon16 from '~/assets/favicons/favicon-16x16.png';
---

<link rel="shortcut icon" href={favIcon} />
<link rel="icon" type="image/svg+xml" href={favIconSvg.src} />
<link rel="icon" type="image/png" sizes="96x96" href={favicon96.src} />
<link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
<link rel="icon" type="image/png" sizes="16x16" href={favicon16.src} />
<link rel="mask-icon" href={favIconSvg.src} color="#1976d2" />
<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
<meta name="msapplication-TileColor" content="#1976d2" />
