---
import { getAsset } from '~/utils/permalinks';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- SEO técnico avanzado -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="author" content="MonkeyJobs S.A.S." />
<meta name="copyright" content="MonkeyJobs S.A.S." />
<meta name="language" content="es-CO" />
<meta name="classification" content="Business, Software Development, Technology" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />
<meta name="target" content="all" />
<meta name="theme-color" content="#03163b" />

<!-- Geo tags — SEO local Bogotá -->
<meta name="geo.region" content="CO-DC" />
<meta name="geo.placename" content="Bogotá" />
<meta name="geo.position" content="4.7110;-74.0721" />
<meta name="ICBM" content="4.7110, -74.0721" />

<!-- Preconnect / dns-prefetch a CDNs críticos -->
<link rel="preconnect" href="https://images.unsplash.com" crossorigin />
<link rel="dns-prefetch" href="https://images.unsplash.com" />

<!-- Web App Manifest (PWA) -->
<link rel="manifest" href={getAsset('/manifest.webmanifest')} />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />
