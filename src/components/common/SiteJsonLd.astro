const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: 'MonkeyJobs',
  description:
    'Sitio web oficial de MonkeyJobs S.A.S. — casa de desarrollo de software en Bogotá.',
  publisher: { '@id': `${siteUrl}/#organization` },
  inLanguage: 'es-CO',
};

const webPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${currentUrl}/#webpage`,
  url: currentUrl,
  name: pageTitle || METADATA?.title?.default || 'MonkeyJobs',
  description: pageDescription || METADATA?.description,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/#organization` },
  primaryImageOfPage: ogImageUrl,
  inLanguage: 'es-CO',
};
---

<StructuredData data={organization} />
<StructuredData data={localBusiness} />
<StructuredData data={website} />
<StructuredData data={webPage} />
