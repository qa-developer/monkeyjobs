const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${siteUrl}/#localbusiness`,
  name: 'MonkeyJobs — Casa de Desarrollo de Software',
  description:
    'Desarrollo de software a la medida en Bogotá. Web, apps móviles, IA y sistemas empresariales.',
