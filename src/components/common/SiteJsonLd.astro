---
import { SITE, METADATA } from 'astrowind:config';
import StructuredData from '~/components/common/StructuredData.astro';
import logoImage from '~/assets/images/logo_monkeyjobs.png';

export interface Props {
  pageTitle?: string;
  pageDescription?: string;
}

const { pageTitle, pageDescription } = Astro.props;

const siteUrl = SITE?.site || '';
const logoUrl = new URL(logoImage.src, siteUrl).toString();

const currentUrl = new URL(Astro.url.pathname, siteUrl).toString().replace(/\/$/, '') || siteUrl;
const ogImageUrl = new URL('/og-monkeyjobs.png', siteUrl).toString();

const organization = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'SoftwareCompany'],
  '@id': `${siteUrl}/#organization`,
  name: 'MonkeyJobs S.A.S.',
  alternateName: ['MonkeyJobs', 'MonkeyJobs Casa de Desarrollo de Software'],
  slogan: 'Software a la medida con IA + ingeniería sólida',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: logoUrl,
    width: 512,
    height: 512,
  },
  image: logoUrl,
  description:
    'Casa de desarrollo de software en Bogotá. Construimos web, apps móviles, sistemas empresariales e inteligencia artificial a la medida.',
  foundingDate: '2017',
  telephone: '+573013859952',
  email: 'javierbr1277@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bogotá',
    addressLocality: 'Bogotá',
    addressRegion: 'Cundinamarca',
    postalCode: '110111',
    addressCountry: 'CO',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '4.7110',
    longitude: '-74.0721',
  },
  areaServed: [
    { '@type': 'Country', name: 'Colombia' },
    { '@type': 'Country', name: 'México' },
    { '@type': 'Country', name: 'Chile' },
    { '@type': 'Country', name: 'Estados Unidos' },
    { '@type': 'Country', name: 'España' },
    { '@type': 'Place', name: 'Latinoamérica' },
  ],
  priceRange: '$$',
  currenciesAccepted: 'COP, USD',
  paymentAccepted: 'Transferencia bancaria, ACH, Tarjeta de crédito',
  numberOfEmployees: {
    '@type': 'QuantitativeValue',
    minValue: 20,
    maxValue: 50,
  },
  knowsAbout: [
    'Desarrollo de Software a la Medida',
    'Desarrollo Web',
    'Desarrollo de Aplicaciones Móviles',
    'iOS Native Development',
    'Android Native Development',
    'Flutter Development',
    'React Native',
    'Angular Development',
    'React Development',
    'Vue.js Development',
    'Astro Framework',
    'Next.js',
    'TypeScript',
    'Node.js Backend',
    '.NET Development',
    'Python Backend',
    'Go Backend',
    'Inteligencia Artificial',
    'Large Language Models',
    'Agentes Autónomos',
    'RAG Architecture',
    'OpenAI API Integration',
    'Machine Learning',
    'APIs REST',
