---
const HIDE_AFTER_MS = 2400;
const DESTROY_AFTER_MS = 3000;
---

<!-- CSS crítico inline (NO scoped): se aplica antes de cualquier hoja async,
     así el overlay tapa el FOUC del menú/contenido en dev y en producción. -->
<style is:inline>
  #mj-preloader {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    background: #03163b;
    z-index: 99999;
    opacity: 1;
    visibility: visible;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      opacity 0.5s ease-out,
      visibility 0s 0.5s;
  }
  #mj-preloader.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  #mj-preloader .mj-pl-spinner {
    display: flex;
  }
  #mj-preloader .mj-pl-bounce {
    height: 45px;
    width: 45px;
    border-radius: 50%;
    display: inline-block;
    animation: mj-pl-bounces 1s ease-in-out infinite alternate;
    transform-origin: 50% 50%;
  }
  #mj-preloader .mj-pl-bounce--two {
    animation-delay: 0.4s;
  }
  #mj-preloader .mj-pl-bounce--three {
    animation-delay: 0.8s;
  }
  #mj-preloader .mj-pl-bounce + .mj-pl-bounce {
    margin-left: 15px;
  }
  #mj-preloader .mj-pl-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @keyframes mj-pl-bounces {
    0% {
      transform: scale(1);
      background: #e5eaf1;
    }
    50% {
      background: #e5eaf1;
    }
    100% {
      transform: scale(0.2);
      background: #e5eaf1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #mj-preloader .mj-pl-bounce {
      animation-duration: 2s;
    }
  }
</style>

<div
  id="mj-preloader"
  role="status"
  aria-live="polite"
  aria-label="Cargando MonkeyJobs"
  data-hide-after={HIDE_AFTER_MS}
  data-destroy-after={DESTROY_AFTER_MS}
>
  <div class="mj-pl-spinner" aria-hidden="true">
    <div class="mj-pl-bounce mj-pl-bounce--one"></div>
    <div class="mj-pl-bounce mj-pl-bounce--two"></div>
    <div class="mj-pl-bounce mj-pl-bounce--three"></div>
  </div>
  <span class="mj-pl-sr">Cargando…</span>
</div>

<script is:inline>
  (function () {
    var loader = document.getElementById('mj-preloader');
    if (!loader) return;
    var seen = false;
    try {
      seen = sessionStorage.getItem('mj-preloader-shown') === '1';
    } catch (e) {}

    function hide() {
      loader.classList.add('is-hidden');
    }

    if (seen) {
      // Navegación interna: tapa el FOUC un instante corto y oculta al cargar.
      if (document.readyState === 'complete') {
        window.setTimeout(hide, 120);
      } else {
        window.addEventListener('load', function () {
          window.setTimeout(hide, 120);
        });
      }
      return;
    }

    // Primera carga de la sesión: muestra la animación completa.
    var destroyAfter = Number(loader.dataset.destroyAfter || 2400);
    window.setTimeout(function () {
      hide();
      try {
        sessionStorage.setItem('mj-preloader-shown', '1');
      } catch (e) {}
    }, destroyAfter);
  })();
</script>
