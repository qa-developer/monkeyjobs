# Copiar a `.env` y rellenar con valores reales.
# `.env` esta en .gitignore, no se commitea.

# EmailJS (formulario de contacto)
# Crea cuenta + service + template en https://dashboard.emailjs.com/
PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
